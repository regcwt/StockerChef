{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Electron Main",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist-electron/**/*.js"],
      "sourceMapPathOverrides": {
        "${workspaceFolder}/*": "${workspaceFolder}/*"
      },
      "timeout": 10000
    }
  ]
}
